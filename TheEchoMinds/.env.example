PORT=5000
MONGODB_URI=mongodb+srv://...
JWT_SECRET=your_secret_change_in_production
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173,https://theechominds.com,https://www.theechominds.com
# Full URL must include /api, or use bare http://localhost:5000 (client auto-appends /api)
VITE_API_URL=http://localhost:5000/api
RAZORPAY_KEY_ID=rzp_xxx
RAZORPAY_KEY_SECRET=xxx
RESEND_API_KEY=re_xxx
# Use quotes when the address contains < > so dotenv does not break the next line.
RESEND_FROM="TheEchoMinds <onboarding@resend.dev>"
VITE_RAZORPAY_KEY_ID=rzp_xxx

# Optional: override hero background (default is /VIDEO.mp4 from public/VIDEO.mp4).
# VITE_HERO_VIDEO_URL=https://res.cloudinary.com/.../video/upload/....mp4
VITE_HERO_VIDEO_URL=

# Glasses demo video (HTTPS; must allow anonymous GET in the browser).
# VITE_GLASSES_VIDEO_URL=https://your-bucket.s3.region.amazonaws.com/glasses.mp4

# Optional — Cloudinary API (e.g. other upload tooling), not used for glasses playback.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME= / CLOUDINARY_API_KEY= / CLOUDINARY_API_SECRET=
